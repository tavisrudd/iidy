title: ConcatMap Transformation Demo
service_endpoints:
  - name: api-internal
    type: internal
    port: 3000
  - name: api-external
    type: external
    port: 8080
  - name: web-internal
    type: internal
    port: 3000
  - name: web-external
    type: external
    port: 8080
  - name: worker-internal
    type: internal
    port: 3000
  - name: worker-external
    type: external
    port: 8080
deployments:
  - service: api
    environment: dev
    name: api-dev
  - service: api
    environment: staging
    name: api-staging
  - service: api
    environment: production
    name: api-production
  - service: web
    environment: dev
    name: web-dev
  - service: web
    environment: staging
    name: web-staging
  - service: web
    environment: production
    name: web-production
  - service: worker
    environment: dev
    name: worker-dev
  - service: worker
    environment: staging
    name: worker-staging
  - service: worker
    environment: production
    name: worker-production
user_permissions:
  - username: alice
    team: backend
