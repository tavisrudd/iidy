  - username: alice
    team: frontend
    permission: alice:frontend
  - username: bob
    team: devops
    permission: bob:devops
  - username: charlie
    team: backend
    permission: charlie:backend
  - username: charlie
    team: data
    permission: charlie:data
indexed_services:
  - service_id: '0'
    service_name: api
    primary: true
  - service_id: '0'
    service_name: api-backup
    primary: false
  - service_id: '1'
    service_name: web
    primary: true
  - service_id: '1'
    service_name: web-backup
    primary: false
  - service_id: '2'
    service_name: worker
    primary: true
  - service_id: '2'
    service_name: worker-backup
    primary: false
production_configs:
  - name: api-config
    type: config
  - name: api-secret
    type: secret
  - name: web-config
    type: config
  - name: web-secret
    type: secret
team_assignments:
